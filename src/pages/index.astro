---
import { existsSync } from 'fs';
import { join } from 'path';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getRepos, archiveIndex, type Repo } from '../lib/github';

const repos = await getRepos();
repos.sort((a, b) => b.stargazers_count - a.stargazers_count);

// Repos with screenshots are featured; the rest use the compact card style
const featured: Repo[] = repos.filter(r => hasScreenshot(r.name));
const secondary: Repo[] = repos.filter(r => !hasScreenshot(r.name));

// Aggregate stats
const totalStars = repos.reduce((sum, r) => sum + r.stargazers_count, 0);

// Language distribution from primary language of each repo
const langCounts: Record<string, number> = {};
repos.forEach(r => {
  if (r.language) langCounts[r.language] = (langCounts[r.language] || 0) + 1;
});
const topLangs = Object.entries(langCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 4)
  .map(([name, count]) => ({ name, pct: Math.round((count / repos.length) * 100) }));

function hasScreenshot(repoName: string): boolean {
  return existsSync(join(process.cwd(), 'public', 'screenshots', `${repoName}.png`));
}
---

<BaseLayout activeNav="projects">
  <main class="max-w-7xl mx-auto px-6 py-20">

    <!-- Hero -->
    <header class="mb-24 flex flex-col items-start gap-4">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-secondary-container rounded-sm">
        <span class="material-symbols-outlined text-[14px] text-primary" style="font-variation-settings: 'FILL' 1;">terminal</span>
        <span class="text-[0.6875rem] font-medium tracking-[0.2em] uppercase font-label text-on-secondary-container">
          Tools.Index
        </span>
      </div>
      <h1 class="font-headline font-bold text-5xl md:text-7xl lg:text-[5rem] tracking-tight leading-[1.05] text-on-surface max-w-4xl">
        Building the <span class="text-primary italic">invisible</span> architecture
      </h1>
      <p class="mt-4 text-on-surface-variant font-body text-lg max-w-xl leading-relaxed">
        A curated ledger of technical explorations. Engineered for precision and architectural longevity.
      </p>
    </header>

    <!-- Main grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">

      <!-- Left: repos -->
      <section class="md:col-span-8 flex flex-col gap-8">

        <!-- Featured cards (repos with screenshots) -->
        {featured.map((repo, i) => (
          <article class="bg-surface p-10 rounded-lg shadow-[0_32px_64px_-4px_rgba(229,225,228,0.06)] relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-64 h-64 technical-gradient opacity-10 blur-[80px] -mr-32 -mt-32 pointer-events-none" />
            <div class="relative z-10">
              <div class="flex justify-between items-start mb-8">
                <div>
                  <span class="text-primary font-headline text-sm tracking-widest uppercase">
                    Index: {archiveIndex(i)}
                  </span>
                  <h2 class="font-headline font-semibold text-3xl mt-2 tracking-tight">
                    {repo.name}
                  </h2>
                </div>
                {repo.language && (
                  <span class="px-2 py-1 bg-surface-container-highest text-[10px] tracking-tighter font-label text-on-surface-variant rounded-sm">
                    {repo.language}
                  </span>
                )}
              </div>

              <div class="aspect-video w-full rounded-lg bg-surface-container-low mb-8 relative overflow-hidden">
                <img
                  src={`/screenshots/${repo.name}.png`}
                  alt={`Screenshot of ${repo.name}`}
                  class="object-contain w-full h-full opacity-60 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-700"
                />
              </div>

              {repo.description && (
                <p class="text-on-surface-variant leading-relaxed max-w-2xl mb-8">
                  {repo.description}
                </p>
              )}

              <div class="flex items-center gap-6">
                <a
                  href={`/projects/${repo.name}`}
                  class="technical-gradient text-on-primary-fixed font-headline font-bold text-xs uppercase tracking-widest px-6 py-3 rounded-md hover:opacity-90 transition-opacity"
                >
                  View Details
                </a>
                <a
                  href={repo.html_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-headline font-bold text-xs uppercase tracking-widest px-6 py-3 rounded-md
                         bg-surface-container-high text-on-surface hover:bg-surface-container-highest transition-colors"
                >
                  GitHub
                </a>
                <div class="flex items-center gap-4 text-on-surface-variant">
                  <div class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">star</span>
                    <span class="text-xs font-label">{repo.stargazers_count.toLocaleString()}</span>
                  </div>
                  <div class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">fork_right</span>
                    <span class="text-xs font-label">{repo.forks_count.toLocaleString()}</span>
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))}

        <!-- Secondary cards (repos without screenshots) -->
        {secondary.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {secondary.map((repo, i) => (
              <article class="bg-surface-container-low p-8 rounded-lg group">
                <span class="text-on-surface-variant font-headline text-[10px] tracking-[0.3em] uppercase">
                  Archive: {archiveIndex(featured.length + i)}
                </span>
                <h3 class="font-headline font-semibold text-xl mt-4 mb-3">{repo.name}</h3>
                <p class="text-on-surface-variant text-sm leading-relaxed mb-6 line-clamp-3">
                  {repo.description ?? 'No description provided.'}
                </p>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    {repo.language && (
                      <span class="text-[10px] font-label text-primary uppercase tracking-widest">
                        {repo.language}
                      </span>
                    )}
                    <div class="flex items-center gap-1 text-outline">
                      <span class="material-symbols-outlined text-[14px]">star</span>
                      <span class="text-[10px] font-label">{repo.stargazers_count}</span>
                    </div>
                  </div>
                  <a
                    href={`/projects/${repo.name}`}
                    aria-label={`View ${repo.name}`}
                    class="text-primary group-hover:translate-x-1 transition-transform"
                  >
                    <span class="material-symbols-outlined">arrow_right_alt</span>
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}
      </section>

      <!-- Sidebar -->
      <aside class="md:col-span-4 flex flex-col gap-8">

        <!-- Global Activity -->
        <div class="bg-surface-container p-8 rounded-lg">
          <h4 class="font-headline font-bold text-xs uppercase tracking-widest text-on-surface-variant mb-6 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full technical-gradient"></span>
            Global Activity
          </h4>
          <div class="flex flex-col gap-6">
            <div class="flex justify-between items-end pb-4 border-b border-outline-variant/10">
              <span class="text-xs font-label text-on-surface-variant">Total Stars</span>
              <span class="font-headline font-medium text-xl">{totalStars.toLocaleString()}</span>
            </div>
            <div class="flex justify-between items-end pb-4 border-b border-outline-variant/10">
              <span class="text-xs font-label text-on-surface-variant">Public Repos</span>
              <span class="font-headline font-medium text-xl">{repos.length}</span>
            </div>
            {topLangs[0] && (
              <div class="flex justify-between items-end">
                <span class="text-xs font-label text-on-surface-variant">Top Language</span>
                <span class="font-headline font-medium text-xl text-primary">{topLangs[0].name}</span>
              </div>
            )}
          </div>
        </div>

        <!-- Language Distribution -->
        {topLangs.length > 0 && (
          <div class="bg-surface-container-high p-8 rounded-lg">
            <h4 class="font-headline font-bold text-xs uppercase tracking-widest text-on-surface-variant mb-6">
              Language Distribution
            </h4>
            <div class="space-y-4">
              {topLangs.map(({ name, pct }) => (
                <div>
                  <div class="flex justify-between text-[10px] font-label uppercase tracking-wider mb-2">
                    <span>{name}</span>
                    <span>{pct}%</span>
                  </div>
                  <div class="h-[2px] w-full bg-surface-container-lowest overflow-hidden rounded-full">
                    <div class="h-full bg-primary" style={`width: ${pct}%`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- All repos quick-link -->
        <div class="p-8 bg-surface-container-low rounded-lg flex flex-col gap-4">
          <span class="material-symbols-outlined text-primary text-3xl">folder_open</span>
          <h4 class="font-headline font-semibold text-lg">Full Archive</h4>
          <p class="text-on-surface-variant text-sm leading-relaxed">
            {repos.length} repositories. All public, no forks.
          </p>
          <a
            href="https://github.com/nazuraki?tab=repositories"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full flex items-center justify-center gap-2 mt-2 py-3 rounded-md
                   bg-surface-container-highest text-primary font-headline font-bold text-xs
                   uppercase tracking-widest hover:bg-surface-bright transition-colors"
          >
            <span class="material-symbols-outlined text-[16px]">hub</span>
            View on GitHub
          </a>
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>
