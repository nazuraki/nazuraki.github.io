---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  activeNav?: 'projects' | 'experience' | 'about' | 'contact';
}

const {
  title = 'nazuraki',
  description = 'A curated ledger of technical explorations. Engineered for precision and architectural longevity.',
  activeNav,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'nazuraki' ? title : `${title} | nazuraki`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
  </head>
  <body class="bg-surface-container-lowest text-on-surface font-body antialiased">
    <Nav activeNav={activeNav} />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    font-family: 'Material Symbols Outlined';
    font-style: normal;
    display: inline-block;
    line-height: 1;
    text-transform: none;
    letter-spacing: normal;
    word-wrap: normal;
    white-space: nowrap;
    direction: ltr;
    user-select: none;
  }

  .technical-gradient {
    background: linear-gradient(135deg, #cebdff 0%, #4c3e76 100%);
  }

  .glass-overlay {
    backdrop-filter: blur(24px);
  }

  ::-webkit-scrollbar {
    width: 4px;
  }
  ::-webkit-scrollbar-thumb {
    background: #494553;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
</style>
